# ScrowX Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file — it is listed in .gitignore.

# ── Database ────────────────────────────────────────────────────────────────
# Local development database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/scrowx_dev"

# Production database (e.g. Railway, Supabase, Neon)
PROD_DATABASE_URL="postgresql://USER:PASSWORD@host:PORT/dbname"

# ── API ─────────────────────────────────────────────────────────────────────
# Frontend API base URL (Vite)
VITE_API_URL=http://localhost:3000

# xAI Grok API key — generate at: https://console.x.ai
GROK_API_KEY="xai-your-api-key-here"

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — use a long random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-random-secret-here"
