// ScrowX Prisma Schema --- v2.0
// Single ORM: Prisma only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------- USER AUTH ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum UserStatus {
  active
  inactive
  suspended
}

model Buyer {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  country      String?
  isVerified   Boolean    @default(false)
  kycComplete  Boolean    @default(false)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?
  profileImage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([email])
  @@index([status])
}

model Seller {
  id             String     @id @default(uuid())
  email          String     @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  country        String?
  businessName   String?
  isVerified     Boolean    @default(false)
  kycComplete    Boolean    @default(false)
  status         UserStatus @default(active)
  lastLoginAt    DateTime?
  profileImage   String?
  totalDeeds     Int        @default(0)
  completedDeeds Int        @default(0)
  rating         Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([email])
  @@index([status])
}

model Admin {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  name        String
  role        String    @default("admin")
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --------- ENUMS ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum DeedStatus {
  DRAFT
  PENDING_SELLER
  PENDING_SIGNATURES
  ACTIVE
  ESCROW_LOCKED
  IN_PROGRESS
  SUBMITTED
  CONFIRMED
  DISPUTED
  ARBITRATING
  ARBITRATED
  ESCALATED
  CLOSED
  CANCELLED
  CHANGES_REQUESTED
}

enum DisputeStatus {
  OPEN
  COUNTER_WINDOW
  ARBITRATING
  AI_DECIDED
  ESCALATED
  RESOLVED
}

enum DisputeReason {
  QUALITY_ISSUE
  DEADLINE_MISSED
  FAKE_DELIVERY
  INCOMPLETE_WORK
  NON_PAYMENT
  OTHER
}

enum TransactionType {
  SERVICE
  GOODS
  DEPOSIT
  RENTAL
  P2P_LOAN
  CUSTOM
}

enum EscalationStatus {
  PENDING
  ASSIGNED
  RESOLVED
}

// --------- DEED ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Deed {
  id                  String          @id @default(uuid())
  title               String
  transactionType     TransactionType @default(SERVICE)
  description         String
  acceptanceCriteria  String

  buyerId             String
  sellerId            String?
  inviteToken         String?         @unique
  inviteExpiresAt     DateTime?

  amount             Int
  currency            String          @default("INR")
  paymentMethod       String?
  paymentReference    String?

  deadline            DateTime?
  revisionLimit       Int             @default(3)
  revisionCount       Int             @default(0)
  deliverableFormats  String[]        @default([])
  isMilestone         Boolean         @default(false)
  scopeBox            Json?


  contentHash         String?
  buyerSignedAt       DateTime?
  sellerSignedAt      DateTime?
  disputeWindowEnds   DateTime?

  status              DeedStatus      @default(DRAFT)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  milestones          Milestone[]
  deedDispute        DeedDispute?
  chatRoom            DeedChatRoom?
  ledgerEntries       AuditLedger[]
  review              Review?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([inviteToken])
}

// --------- MILESTONE ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Milestone {
  id                 String    @id @default(uuid())
  deedId             String
  deed               Deed      @relation(fields: [deedId], references: [id], onDelete: Cascade)
  milestoneNumber    Int
  title              String
  description        String?
  acceptanceCriteria String?
  amount             Int
  deadline           DateTime?
  autoPay            Boolean   @default(false)
  status             String    @default("PENDING")
  submittedAt        DateTime?
  approvedAt         DateTime?
  paidAt             DateTime?
  createdAt          DateTime  @default(now())

  @@index([deedId])
}

// --------- AUDIT LEDGER ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model AuditLedger {
  id             String   @id @default(uuid())
  deedId         String
  deed           Deed     @relation(fields: [deedId], references: [id])
  eventType      String
  actorRole      String
  actorId        String
  payloadHash    String
  prevEntryHash  String
  entryHash      String
  sequenceNumber Int
  timestamp      DateTime @default(now())
  payload        String
  createdAt      DateTime @default(now())

  @@index([deedId, sequenceNumber])
  @@index([deedId])
}

// 

// --------- KYC ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model KYC {
  id            String    @id @default(uuid())
  userId        String    @unique
  userRole      String
  phone         String
  phoneVerified   Boolean   @default(false)
  fullLegalName   String
  dateOfBirth     String
  
  idDocType       String?
  idDocUrls       String[]  @default([])
  submittedAt     DateTime?
  reviewStatus    String    @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?
  kycComplete     Boolean   @default(false)
  
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model OTPRecord {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

// --------- WALLET ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Wallet {
  id            String              @id @default(uuid())
  userId        String              @unique
  userRole      String
  currency      String              @default("INR")
  balance            Int               @default(0)
  lockedBalance      Int               @default(0)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  transactions  WalletTransaction[]
}

model WalletTransaction {
  id                String   @id @default(uuid())
  walletId          String
  wallet            Wallet   @relation(fields: [walletId], references: [id])
  type              String
  category          String
  amount             Int
  currency          String   @default("INR")
  status            String   @default("PENDING")
  description       String
  reference         String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpayPayoutId  String?
  fee                 Int    @default(0)
  netAmount           Int    @default(0)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// --------- WEBHOOKS -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model WebhookEvent {
  id          String   @id // Maps to x-razorpay-event-id
  provider    String   @default("RAZORPAY")
  status      String   @default("PROCESSED") // To track state
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// --------- CHAT ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model DeedChatRoom {
  id         String        @id @default(uuid())
  deedId     String        @unique
  deed       Deed          @relation(fields: [deedId], references: [id])
  buyerId    String
  sellerId   String
  isActive   Boolean       @default(true)
  isArchived Boolean       @default(false)
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]
}

model ChatMessage {
  id         String       @id @default(uuid())
  roomId     String
  room       DeedChatRoom @relation(fields: [roomId], references: [id])
  senderId   String
  senderRole String
  senderName String
  content    String
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())
}



// --------- ORDER DISPUTE -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum DeedDisputeStatus {
  OPEN
  CHALLENGE_PHASE
  ESCALATED
  RESOLVED
}

enum DeedDisputePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model DeedDispute {
  id                   String               @id @default(uuid())
  deedId               String?              @unique
  deed                 Deed?                @relation(fields: [deedId], references: [id])
  buyerId              String
  sellerId             String
  raisedBy             String               // "buyer" | "seller"
  reason               String
  description          String
  evidenceUrls         String[]             @default([])
  requestedResolution  String?

  priority             DeedDisputePriority @default(MEDIUM)
  status               DeedDisputeStatus   @default(OPEN)

  // @deprecated - replaced by DisputeEvent
  ruleFlags            Json?                
  // @deprecated - replaced by DisputeEvent
  aiAnalysis           Json?                
  // @deprecated - replaced by DisputeEvent
  evidenceResponses    Json                 @default("{}")
  // @deprecated - replaced by DisputeEvent
  timeline             Json                 @default("[]")

  resolution           String?              // "REFUND_BUYER" | "RELEASE_TO_SELLER"
  // @deprecated - tracked via DisputeEvent
  resolvedBy           String?
  // @deprecated - tracked via DisputeEvent
  resolvedAt           DateTime?
  // @deprecated - tracked via DisputeEvent
  escalatedAt          DateTime?
  autoFlaggedAt        DateTime?
  // @deprecated - tracked via DisputeEvent
  lastActivity         DateTime?

  // @deprecated - replaced by DisputeEvent
  enhancedAnalysis     Json?
  // @deprecated - replaced by DisputeEvent
  scopeCompliance      Json?

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  events               DisputeEvent[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

enum DisputeEventType {
  EVIDENCE_SUBMITTED
  AI_REPORT
  CHALLENGE
  ESCALATED
  HUMAN_DECISION
  SETTLEMENT
}

model DisputeEvent {
  id              String           @id @default(uuid())
  deedDisputeId   String
  deedDispute     DeedDispute      @relation(fields: [deedDisputeId], references: [id], onDelete: Cascade)
  
  type            DisputeEventType
  actorRole       String           // "buyer" | "seller" | "ai" | "admin" | "system"
  actorId         String?          
  
  payload         Json             
  
  createdAt       DateTime         @default(now())

  @@index([deedDisputeId])
  @@index([type])
}



// --------- NOTIFICATIONS -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Notification {
  id        String   @id @default(uuid())
  userId    String
  userRole  String   // "buyer" | "seller"
  type      String   // e.g., "ORDER_UPDATE", "DISPUTE", "WALLET"
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  // Optional navigation path
  createdAt DateTime @default(now())
  
  @@index([userId, userRole])
}

// --------- REVIEWS -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Review {
  id        String   @id @default(uuid())
  deedId    String   @unique
  deed      Deed     @relation(fields: [deedId], references: [id])
  buyerId   String
  sellerId  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([buyerId])
}
