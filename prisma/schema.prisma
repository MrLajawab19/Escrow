// ScrowX Prisma Schema --- v2.0
// Single ORM: Prisma only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------- USER AUTH ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum UserStatus {
  active
  inactive
  suspended
}

model Buyer {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  country      String?
  isVerified   Boolean    @default(false)
  kycComplete  Boolean    @default(false)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?
  profileImage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([email])
  @@index([status])
}

model Seller {
  id             String     @id @default(uuid())
  email          String     @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  country        String?
  businessName   String?
  isVerified     Boolean    @default(false)
  kycComplete    Boolean    @default(false)
  status         UserStatus @default(active)
  lastLoginAt    DateTime?
  profileImage   String?
  totalDeeds     Int        @default(0)
  completedDeeds Int        @default(0)
  rating         Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([email])
  @@index([status])
}

model Admin {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  name        String
  role        String    @default("admin")
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --------- ENUMS ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum DeedStatus {
  DRAFT
  PENDING_SELLER
  PENDING_SIGNATURES
  ACTIVE
  ESCROW_LOCKED
  IN_PROGRESS
  SUBMITTED
  CONFIRMED
  DISPUTED
  ARBITRATING
  ARBITRATED
  ESCALATED
  CLOSED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  COUNTER_WINDOW
  ARBITRATING
  AI_DECIDED
  ESCALATED
  RESOLVED
}

enum DisputeReason {
  QUALITY_ISSUE
  DEADLINE_MISSED
  FAKE_DELIVERY
  INCOMPLETE_WORK
  NON_PAYMENT
  OTHER
}

enum TransactionType {
  SERVICE
  GOODS
  DEPOSIT
  RENTAL
  P2P_LOAN
  CUSTOM
}

enum EscalationStatus {
  PENDING
  ASSIGNED
  RESOLVED
}

// --------- DEED ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Deed {
  id                  String          @id @default(uuid())
  title               String
  transactionType     TransactionType @default(SERVICE)
  description         String
  acceptanceCriteria  String

  buyerId             String
  sellerId            String?
  inviteToken         String?         @unique
  inviteExpiresAt     DateTime?

  amount              Float
  currency            String          @default("INR")
  paymentMethod       String?
  paymentReference    String?

  deadline            DateTime?
  revisionLimit       Int             @default(0)
  deliverableFormats  String[]        @default([])
  isMilestone         Boolean         @default(false)
  scopeBox            Json?


  contentHash         String?
  buyerSignedAt       DateTime?
  sellerSignedAt      DateTime?
  disputeWindowEnds   DateTime?

  status              DeedStatus      @default(DRAFT)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  milestones          Milestone[]
  dispute             Dispute?
  chatRoom            DeedChatRoom?
  ledgerEntries       AuditLedger[]
  review              Review?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([inviteToken])
}

// --------- MILESTONE ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Milestone {
  id                 String    @id @default(uuid())
  deedId             String
  deed               Deed      @relation(fields: [deedId], references: [id], onDelete: Cascade)
  milestoneNumber    Int
  title              String
  description        String?
  acceptanceCriteria String?
  amount             Float
  deadline           DateTime?
  autoPay            Boolean   @default(false)
  status             String    @default("PENDING")
  submittedAt        DateTime?
  approvedAt         DateTime?
  paidAt             DateTime?
  createdAt          DateTime  @default(now())

  @@index([deedId])
}

// --------- AUDIT LEDGER ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model AuditLedger {
  id             String   @id @default(uuid())
  deedId         String
  deed           Deed     @relation(fields: [deedId], references: [id])
  eventType      String
  actorRole      String
  actorId        String
  payloadHash    String
  prevEntryHash  String
  entryHash      String
  sequenceNumber Int
  timestamp      DateTime @default(now())
  payload        String
  createdAt      DateTime @default(now())

  @@index([deedId, sequenceNumber])
  @@index([deedId])
}

// --------- DISPUTE ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Dispute {
  id                  String          @id @default(uuid())
  deedId              String          @unique
  deed                Deed            @relation(fields: [deedId], references: [id])
  milestoneId         String?

  raisedById          String
  raisedByRole        String
  reason              DisputeReason
  description         String
  evidenceUrls        String[]
  deedClauseCited     String[]

  counterEvidenceUrls String[]        @default([])
  counterDescription  String?
  counterSubmittedAt  DateTime?
  counterWindowEnds   DateTime?

  dayNumber           Int
  feePercentage       Float
  feeAmount           Float
  feeDeducted         Boolean         @default(false)

  aiVerdict           String?
  aiSellerPct         Int?
  aiBuyerPct          Int?
  aiConfidence        Float?
  aiReasoning         String?
  aiKeyFactors        String[]        @default([])
  aiClauseAnalysis    Json?
  aiFraudLevel        String?
  aiPromptVersion     String?
  aiFlaggedForReview  Boolean         @default(false)
  aiRunAt             DateTime?

  status              DisputeStatus   @default(OPEN)
  resolvedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  escalation          HumanEscalation?

  @@index([deedId])
  @@index([status])
}

// --------- HUMAN ESCALATION ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model HumanEscalation {
  id              String           @id @default(uuid())
  disputeId       String           @unique
  dispute         Dispute          @relation(fields: [disputeId], references: [id])
  requestedById   String
  requestedByRole String
  escalationFee   Float
  feeDeducted     Boolean          @default(false)
  aiVerdictJson   String
  status          EscalationStatus @default(PENDING)
  adminId         String?
  finalVerdict    String?
  sellerPct       Int?
  buyerPct        Int?
  adminReasoning  String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// --------- KYC ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model KYC {
  id            String    @id @default(uuid())
  userId        String    @unique
  userRole      String
  phone         String
  phoneVerified   Boolean   @default(false)
  fullLegalName   String
  dateOfBirth     String
  
  idDocType       String?
  idDocUrls       String[]  @default([])
  submittedAt     DateTime?
  reviewStatus    String    @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?
  kycComplete     Boolean   @default(false)
  
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model OTPRecord {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

// --------- WALLET ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Wallet {
  id            String              @id @default(uuid())
  userId        String              @unique
  userRole      String
  currency      String              @default("INR")
  balance       Float               @default(0)
  lockedBalance Float               @default(0)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  transactions  WalletTransaction[]
}

model WalletTransaction {
  id                String   @id @default(uuid())
  walletId          String
  wallet            Wallet   @relation(fields: [walletId], references: [id])
  type              String
  category          String
  amount            Float
  currency          String   @default("INR")
  status            String   @default("PENDING")
  description       String
  reference         String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpayPayoutId  String?
  fee               Float    @default(0)
  netAmount         Float    @default(0)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// --------- CHAT ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model DeedChatRoom {
  id         String        @id @default(uuid())
  deedId     String        @unique
  deed       Deed          @relation(fields: [deedId], references: [id])
  buyerId    String
  sellerId   String
  isActive   Boolean       @default(true)
  isArchived Boolean       @default(false)
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]
}

model ChatMessage {
  id         String       @id @default(uuid())
  roomId     String
  room       DeedChatRoom @relation(fields: [roomId], references: [id])
  senderId   String
  senderRole String
  senderName String
  content    String
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())
}

// --------- ORDER ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum OrderStatus {
  PLACED
  ESCROW_FUNDED
  ACCEPTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  COMPLETED
  DISPUTED
  CHANGES_REQUESTED
  REJECTED
  CANCELLED
  REFUNDED
  RELEASED
}

model Order {
  id                 String        @id @default(uuid())
  buyerId            String
  sellerId           String?
  buyerName          String
  buyerEmail         String
  platform           String
  productLink        String?
  country            String
  currency           String        @default("INR")
  sellerContact      String
  escrowLink         String?
  orderTrackingLink  String?
  scopeBox           Json
  status             OrderStatus   @default(PLACED)
  deliveryFiles      String[]      @default([])
  orderLogs          Json          @default("[]")
  proposedScopeBox   Json?
  sellerAcceptedAt   DateTime?
  disputeId          String?
  revisionCount      Int           @default(0)
  formalNoticeCount  Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  dispute            OrderDispute?
  chatRoom           OrderChatRoom?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// --------- ORDER DISPUTE -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

enum OrderDisputeStatus {
  OPEN
  RESPONDED
  UNDER_REVIEW
  MEDIATION
  RESOLVED
}

enum OrderDisputePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model OrderDispute {
  id                   String               @id @default(uuid())
  orderId              String               @unique
  order                Order                @relation(fields: [orderId], references: [id])

  buyerId              String
  sellerId             String
  raisedBy             String               // "buyer" | "seller"
  reason               String
  description          String
  evidenceUrls         String[]             @default([])
  requestedResolution  String?

  priority             OrderDisputePriority @default(MEDIUM)
  status               OrderDisputeStatus   @default(OPEN)

  ruleFlags            Json?                // output of runDisputeEngine
  aiAnalysis           Json?                // output of analyzeDisputeWithAI
  evidenceResponses    Json                 @default("{}")
  timeline             Json                 @default("[]")

  resolution           String?              // "REFUND_BUYER" | "RELEASE_TO_SELLER"
  resolvedBy           String?
  resolvedAt           DateTime?
  escalatedAt          DateTime?
  autoFlaggedAt        DateTime?
  lastActivity         DateTime?

  enhancedAnalysis     Json?
  scopeCompliance      Json?

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// --------- ORDER CHAT ROOM -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model OrderChatRoom {
  id         String         @id @default(uuid())
  orderId    String         @unique
  order      Order          @relation(fields: [orderId], references: [id])
  buyerId    String
  sellerId   String
  isActive   Boolean        @default(true)
  isArchived Boolean        @default(false)
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  messages   OrderChatMessage[]

  @@index([orderId])
}

model OrderChatMessage {
  id         String        @id @default(uuid())
  roomId     String
  room       OrderChatRoom @relation(fields: [roomId], references: [id])
  senderId   String
  senderRole String
  senderName String
  content    String
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([roomId])
}

// --------- NOTIFICATIONS -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Notification {
  id        String   @id @default(uuid())
  userId    String
  userRole  String   // "buyer" | "seller"
  type      String   // e.g., "ORDER_UPDATE", "DISPUTE", "WALLET"
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  // Optional navigation path
  createdAt DateTime @default(now())
  
  @@index([userId, userRole])
}

// --------- REVIEWS -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

model Review {
  id        String   @id @default(uuid())
  deedId    String   @unique
  deed      Deed     @relation(fields: [deedId], references: [id])
  buyerId   String
  sellerId  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([buyerId])
}
